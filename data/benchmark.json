    "hardware": "3x NVIDIA H200 141GB HBM3e GPUs on single node",
    "platform": "Red Hat OpenShift 4.21.11 with llm-d (CNCF Sandbox)",
    "inference_engine": "vLLM with automatic prefix caching",
    "methodology": "In-pod measurement via direct HTTPS + streaming SSE. time.perf_counter() for TTFT. Zero network overhead.",
    "routing_comparison": {
      "round_robin": "Standard K8s Service load balancing \u2014 requests distributed evenly across pods",
      "cache_aware": "llm-d EPP routing \u2014 requests routed to the pod with the best KV-cache match"
    },
    "benchmark_suite": [
      "Test 1: Context Length Scaling (500-8000 tokens)",
      "Test 2: Long Prefix Cold/Warm (8000 tokens, all pods)",
      "Test 3: Concurrent Load (10 sessions x 5 turns)",
      "Test 4: Cache Warmup Curve (20 sequential requests)",
      "Test 5: Extended Agentic Chain (12 steps, 10K tokens)",
      "Test 6: Multi-turn Conversations (10 turns, 3 conversations) [original]",
      "Test 7: Agentic Tool-Calling Chain (8 steps, 4.4K tokens) [original]",
      "Test 8: Extended Context Scaling (12K-32K tokens)"
    ]
  },
  "headline_numbers": {
